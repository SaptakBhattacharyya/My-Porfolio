{
  "rewrites": [
    { "source": "/((?!api|_next|static|og-image\\.png|image\\.png|favicon\\.ico|robots\\.txt|sitemap\\.xml|googlea49f8db3fc959f2e\\.html|certificates|games|images).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
